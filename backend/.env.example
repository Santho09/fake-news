# MongoDB Atlas
MONGODB_URI="your_mongodb_atlas_connection_string"
MONGODB_DB="newsveritas"

# Auth
JWT_SECRET="change_me_to_a_long_random_secret"
JWT_EXPIRES_MINUTES="10080"  # 7 days

# Security: only allow creating admin accounts if this matches during signup
ADMIN_SIGNUP_CODE="set_a_secret_code_here"

# CORS
FRONTEND_ORIGIN="http://localhost:5173"
FRONTEND_RESET_URL="http://localhost:5173"

# Google Fact Check Tools API — optional; required for fact_check_mode=google
# https://console.cloud.google.com/apis/library/factchecktools.googleapis.com
GOOGLE_FACT_CHECK_API_KEY=

# Password reset token
RESET_TOKEN_EXPIRES_MINUTES="30"

# SMTP settings (required for forgot-password email delivery)
SMTP_HOST=
SMTP_PORT="587"
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME="NewsVeritas"
SMTP_USE_TLS="true"
